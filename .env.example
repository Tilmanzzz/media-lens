# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL
POSTGRES_DB=audiolens
POSTGRES_USER=audiolens
POSTGRES_PASS=CHANGEME
POSTGRES_URL=postgresql://audiolens:changeme@postgres:5432/audiolens?sslmode=disable

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio:9000
MINIO_USER=minioadmin
MINIO_PASS=CHANGEME
MINIO_USE_SSL=false
MINIO_BUCKET=bronze

# Gemini API (used for summarization, fact-checking, embeddings)
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Embedding Provider (backend semantic search)
# Options: "ollama" | "gemini"
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIMENSION=2560

# Podcast Index API (optional, for feed discovery)
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# Ingestion
# Load mode for the ingestion service (e.g. "full" or "delta")
LOAD_MODE=full
FRONTEND_PUBLIC_URL=http://localhost:3000

# Backend
BACKEND_PORT=:8080
CORS_ORIGINS=http://localhost:3000

# Transcription
# Optional: external Whisper API endpoint (leave empty to use local model)
WHISPER_API_URL=
USE_CUDA=true

# Logging
LOG_LEVEL=INFO
LOG_DIR=/app/logs
