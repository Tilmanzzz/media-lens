{
  "provider": "gemini",
  "model": "gemini-2.5-flash-lite",
  "temperature": 0.0,
  "default_transcript_path": "./test/fact_checker_test_transcript.txt",
  "default_output_path": "./test/output_factchecker.json",
  "region": "us-en",
  "search_backend": "duckduckgo,bing,brave,google,yahoo,mojeek,yandex,wikipedia",
  "search_timeout": 10,
  "max_queries_per_claim": 1,
  "max_search_results_per_query": 3,
  "max_sources_per_claim": 3,
  "max_workers": 4,
  "max_chapter_workers": 2,
  "logging_enabled": true,
  "log_level": "INFO",
  "log_dir": "../logs",
  "log_file": "fact_checker.log",
  "allowed_verdicts": [
    "TRUE",
    "MOSTLY_TRUE",
    "MISLEADING",
    "FALSE",
    "UNVERIFIABLE"
  ],
  "llm_options": {}
}
